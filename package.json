{
  "name": "taskmanagerpwa-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:taskmanager": "npm run dev -w apps/taskmanager",
    "dev:mynotebook": "npm run dev -w apps/mynotebook",
    "dev:worker": "npm run dev:worker -w apps/taskmanager",
    "dev:worker:live": "npm run dev:worker:live -w apps/taskmanager",
    "build": "npm run build -ws",
    "lint": "npm run lint -ws",
    "test": "npm run test -ws",
    "test:e2e": "npm run test:e2e -w apps/taskmanager",
    "test:verify": "npm run test && npm run lint && npm run test:e2e",
    "deploy:taskmanager": "npm run deploy -w apps/taskmanager",
    "deploy:taskmanager:dry-run": "npm run deploy:dry-run -w apps/taskmanager",
    "deploy:mynotebook": "npm run deploy -w apps/mynotebook",
    "deploy:mynotebook:dry-run": "npm run deploy:dry-run -w apps/mynotebook",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "1.0.0-rc.17",
    "lightningcss-linux-x64-gnu": "1.32.0"
  },
  "engines": {
    "node": ">=22"
  }
}
